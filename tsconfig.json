{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
  },
  "include": ["src", "scripts", "bin"],
  "exclude": ["node_modules", "web", "infra", "dist", "src/generated"]
}
