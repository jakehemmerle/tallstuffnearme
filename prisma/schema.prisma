// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  runtime    = "bun"
}

datasource db {
  provider = "postgresql"
}

model FAAObject {
  OASNumber      Int        @id
  Verified       String
  Country        String
  State          String
  City           String
  Latitude       Float
  Longitude      Float
  ObjectType     ObjectType @default(UNDEFINED)
  AGL            Int
  AMSL           Int
  LT             String
  H              String
  AccV           String
  MarInd         String
  FAAStudyNumber String
  Action         String
  JDate          String

  @@index([Latitude, Longitude])
  @@index([AGL])
}

enum ObjectType {
  RIG
  STACK
  BLDG
  TOWER
  POLE
  ELEC_SYS
  TL_TWR
  TANK
  BRIDGE
  SIGN
  REFINERY
  FENCE
  PLANT
  GEN_UTIL
  ELEVATOR
  ANTENNA
  NAVAID
  CTRL_TWR
  SILO
  UTILITY_POLE
  CRANE
  BLDGTWR
  VERTICAL_STRUCTURE
  AG_EQUIP
  CATENARY
  WINDSOCK
  DOME
  SOLAR_PANELS
  MET
  AMUSEMENT_PARK
  MONUMENT
  STADIUM
  COOL_TWR
  DAM
  WINDMILL
  LANDFILL
  POWER_PLANT
  TRAMWAY
  BALLOON
  SPIRE
  WALL
  HEAT_COOL_SYSTEM
  NATURAL_GAS_SYSTEM
  LGTHOUSE
  PIPELINE_PIPE
  HANGAR
  ARCH
  GRAIN_ELEVATOR
  GATE
  WIND_INDICATOR
  UNDEFINED
}
